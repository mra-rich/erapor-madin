# ─── Database Configuration ────────────────────────────────
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=e_raport
DB_PORT=3306
DB_SSL=false

# local = izinkan fallback file session saat tabel sessions belum ada.
# production = wajib memakai DB session.
APP_ENV=local

# ─── Keterangan ──────────────────────────────────────────
# DB_SSL  : Set "true" untuk koneksi via SSL (misal Aiven Cloud)
# DB_PORT : Port MySQL (default 3306)
# Salin file ini menjadi .env dan sesuaikan nilainya untuk setup lokal.
