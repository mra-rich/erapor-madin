{
  "version": 2,
  "regions": ["sin1"],
  "builds": [
    {
      "src": "public/index.php",
      "use": "vercel-php@0.9.0"
    },
    {
      "src": "public/css/**",
      "use": "@vercel/static"
    },
    {
      "src": "public/assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "public/uploads/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/css/(.*)",
      "dest": "/public/css/$1"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/public/uploads/$1"
    },
    {
      "src": "/(.*\\.php)",
      "dest": "/public/index.php?route=$1"
    },
    {
      "src": "/",
      "dest": "/public/index.php?route=index.php"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.php?route=$1"
    }
  ]
}
